FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY lightrag_mcp ./lightrag_mcp

RUN pip install --no-cache-dir \
    "mcp>=1.23,<2" \
    "httpx>=0.28,<1" \
    "PyJWT[crypto]>=2.8,<3" \
    "pydantic>=2,<3" \
    "starlette>=0.37,<1" \
    "uvicorn>=0.30,<1"

EXPOSE 8000

CMD ["uvicorn", "lightrag_mcp.server:app", "--host", "0.0.0.0", "--port", "8000"]

