MCP_DOMAIN=mcp.example.edu
TRAEFIK_NETWORK=n8n-compose_default
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

LIGHTRAG_API_KEY=
LIGHTRAG_MCP_TIMEOUT=120

MCP_AUTH_REQUIRED=true
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://mcp.example.edu
AUTH0_ALGORITHMS=RS256

NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-this-password
NEO4J_DATABASE=neo4j

ENTITY_TYPE_PROMPT_FILE=pem_graphrag_entity_type_prompt.yml

LLM_BINDING=ollama
LLM_BINDING_HOST=http://ollama:11434
LLM_MODEL=qwen2.5:7b
LLM_TIMEOUT=300

EMBEDDING_BINDING=ollama
EMBEDDING_BINDING_HOST=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_TIMEOUT=300
