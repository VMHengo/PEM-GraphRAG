MCP_DOMAIN=mcp.example.edu
LIGHTRAG_WEBUI_DOMAIN=lightrag.example.edu
TRAEFIK_NETWORK=n8n-compose_default
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

LIGHTRAG_API_KEY=
LIGHTRAG_MCP_TIMEOUT=120

MCP_AUTH_REQUIRED=true
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://mcp.example.edu
AUTH0_ALGORITHMS=RS256

# Developer/admin WebUI login via oauth2-proxy in front of LightRAG.
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=
OAUTH2_PROXY_ISSUER_URL=https://your-tenant.eu.auth0.com/
OAUTH2_PROXY_EMAIL_DOMAINS=*

NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-this-password
NEO4J_DATABASE=neo4j

ENTITY_TYPE_PROMPT_FILE=pem_graphrag_entity_type_prompt.yml
ENTITY_EXTRACTION_USE_JSON=true

LLM_BINDING=ollama
LLM_BINDING_HOST=http://ollama:11434
LLM_MODEL=qwen2.5:7b
LLM_BINDING_API_KEY=
LLM_TIMEOUT=300

# Optional: use a stronger model only for entity/relation extraction.
# Leave unset to inherit the normal LLM_* settings.
EXTRACT_LLM_BINDING=
EXTRACT_LLM_BINDING_HOST=
EXTRACT_LLM_MODEL=
EXTRACT_LLM_BINDING_API_KEY=
EXTRACT_LLM_TIMEOUT=900
EXTRACT_MAX_ASYNC_LLM=1
MAX_ASYNC=1

EMBEDDING_BINDING=ollama
EMBEDDING_BINDING_HOST=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_TIMEOUT=300
